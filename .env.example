# Align configuration
# Copy this file to .env and fill in real values. NEVER commit your real .env.

# Adzuna API credentials -> https://developer.adzuna.com/  (App ID + App Key)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Flask session secret (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# Optional: host/port overrides
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=1

# --- £1 paywall ---
# Set PAYWALL_ENABLED=1 to require the £1 unlock during onboarding; 0 runs free.
# (The paywall only activates when this is 1 AND a payment method below is set.)
PAYWALL_ENABLED=1

# Option A (recommended): GoCardless hosted payment link.
# A default project link is baked in, so the paywall works with PAYWALL_ENABLED=1
# alone. Override here with your own link from https://manage.gocardless.com .
GOCARDLESS_PAYMENT_LINK=https://pay.gocardless.com/BRT01KY3S2V89HC5QBH5WG89ZHBE8
# A secret you invent. Set your GoCardless link's "success redirect URL" to
#   <PUBLIC_BASE_URL>/pay/success?token=<this value>
# so only a genuine post-payment return unlocks access.
PAYMENT_RETURN_TOKEN=

# Option B (fallback): Stripe Checkout. Only used if no GoCardless link is set.
# Secret key from https://dashboard.stripe.com/apikeys (sk_test_... or sk_live_...).
STRIPE_SECRET_KEY=

# Access price in pence (100 = £1.00) and currency.
PRICE_PENCE=100
CURRENCY=gbp
# Your app's public URL once deployed, e.g. https://align.onrender.com
# (used to build payment return links; leave blank for local testing).
PUBLIC_BASE_URL=
