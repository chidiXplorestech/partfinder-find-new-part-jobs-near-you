# PartFinder — environment configuration
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
# The `.env` file is git-ignored and must never be committed.

# --- Adzuna Jobs API (free) ---------------------------------------------------
# Sign up for free at https://developer.adzuna.com/ to get your credentials.
# When these are set, PartFinder returns LIVE job listings.
# When they are empty, PartFinder falls back to the bundled seed dataset so the
# app still runs (useful for a first clone / offline demo).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Flask --------------------------------------------------------------------
# Used to sign sessions/flash messages. Generate one with:
#     python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# --- Optional overrides -------------------------------------------------------
# FLASK_DEBUG=1
# DB_PATH=partfinder.sqlite3
# RESULTS_LIMIT=50
